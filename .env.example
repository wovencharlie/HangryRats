# Hangry Rats — environment variables (see README for details).

# Postgres connection string. On Railway, reference the Postgres service:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
# Leave unset for a static-only local run (the leaderboard API returns 503).
DATABASE_URL=

# Solana RPC endpoint used for BOTH the client balance check and the server-side
# re-check. The public endpoint is rate-limited; a free Helius key is recommended.
#   https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Build-time copy of the RPC URL exposed to the browser (Vite only inlines
# vars prefixed with VITE_). Set this to the same value as SOLANA_RPC_URL.
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Password for the owner-only /admin prize list. Admin is DISABLED if unset.
ADMIN_KEY=change-me

# Optional: force SSL on the Postgres connection (Railway public proxy URL).
# PGSSL=1
